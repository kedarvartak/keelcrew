{
  "name": "multi-agent-memo",
  "version": "0.1.0",
  "description": "Shared memory MCP server for Claude, Codex, and Gemini CLI",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "scripts",
    "CLAUDE.md",
    "GEMINI.md",
    "README.md",
    "LICENSE"
  ],
  "bin": {
    "multi-agent-memo": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "node --watch --experimental-strip-types src/index.ts",
    "test": "node --test --experimental-strip-types test/*.test.ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "memory",
    "agents",
    "claude",
    "codex",
    "gemini"
  ],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "multi-agent-memo": "^0.1.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=22"
  }
}
